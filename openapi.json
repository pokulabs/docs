  },
  "components": {
    "responses": {
      "BadRequest": {
        "description": "Validation or request error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication required",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Requested resource was not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NoContent": {
        "description": "No content"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "description": "Generic error shape returned by Express error middleware.",
        "additionalProperties": true
      },
      "TextDirectResponse": {
        "type": "string",
        "description": "Rendered text response, timeout message, or image-links summary."
      },
      "ContactFormDirectResponse": {
        "oneOf": [
          {
            "type": "string",
            "description": "Timeout or no-response message."
          },
          {
            "type": "object",
            "required": [
              "values",
              "content"
            ],
            "properties": {
              "values": {
                "type": "object",
                "additionalProperties": true,
                "description": "Submitted form values."
              },
              "content": {
                "type": "string",
                "description": "Raw form response body."
              }
            },
            "additionalProperties": false
          }
        ]
      },
      "CallResponse": {
        "type": "object",
        "required": [
          "response"
        ],
        "properties": {
          "response": {
            "$ref": "#/components/schemas/TextDirectResponse"
          },
          "interactionId": {
            "type": "string",
            "nullable": true
          },
          "call": {
            "type": "object",
            "required": [
              "recordingUrl"
            ],
            "properties": {
              "recordingUrl": {
                "type": "string",
                "format": "uri"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "ToolWrappedTextResponse": {
        "type": "object",
        "required": [
          "results"
        ],
        "properties": {
          "results": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/TextToolResult"
            }
          }
        },
        "additionalProperties": false
      },
      "ToolWrappedContactFormResponse": {
        "type": "object",
        "required": [
          "results"
        ],
        "properties": {
          "results": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/ContactFormToolResult"
            }
          }
        },
        "additionalProperties": false
      },
      "ToolWrappedCallResponse": {
        "type": "object",
        "required": [
          "results"
        ],
        "properties": {
          "results": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/CallToolResult"
            }
          }
        },
        "additionalProperties": false
      },
      "TextToolResult": {
        "type": "object",
        "required": [
          "toolCallId",
          "result"
        ],
        "properties": {
          "toolCallId": {
            "type": "string"
          },
          "result": {
            "$ref": "#/components/schemas/TextDirectResponse"
          }
        },
        "additionalProperties": false
      },
      "ContactFormToolResult": {
        "type": "object",
        "required": [
          "toolCallId",
          "result"
        ],
        "properties": {
          "toolCallId": {
            "type": "string"
          },
          "result": {
            "$ref": "#/components/schemas/ContactFormDirectResponse"
          }
        },
        "additionalProperties": false
      },
      "CallToolResult": {
        "type": "object",
        "required": [
          "toolCallId",
          "result"
        ],
        "properties": {
          "toolCallId": {
            "type": "string"
          },
          "result": {
            "$ref": "#/components/schemas/CallResponse"
          }
        },
        "additionalProperties": false
      },
      "Message": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      },
      "LongMessage": {
        "type": "string",
        "minLength": 1,
        "maxLength": 10000
      },
      "PhoneOrHandle": {
        "type": "string",
        "minLength": 1,
        "maxLength": 20
      },
      "WaitTime": {
        "type": "number",
        "minimum": 1,
        "maximum": 600,
        "default": 590
      },
      "FollowUpTime": {
        "type": "number",
        "minimum": 1,
        "maximum": 60000,
        "default": 60000
      },
      "Medium": {
        "type": "string",
        "enum": [
          "sms",
          "whatsapp",
          "slack"
        ]
      },
      "WhatsappTemplate": {
        "type": "object",
        "required": [
          "id",
          "variables"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "variables": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "string",
              "minLength": 1,
              "maxLength": 5000
            }
          }
        },
        "additionalProperties": false
      },
      "CaptureFormFieldOption": {
        "type": "object",
        "required": [
          "label",
          "value"
        ],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
