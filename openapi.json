            }
          }
        },
        "responses": {
          "200": {
            "description": "Rendered response text",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/TextDirectResponse"
                    },
                    {
                      "$ref": "#/components/schemas/ToolWrappedTextResponse"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/messages/{channelId}": {
      "post": {
        "tags": [
          "messages"
        ],
        "summary": "Send a message through a saved channel",
        "description": "Requires authentication.",
        "operationId": "sendChannelMessage",
        "parameters": [
          {
            "name": "channelId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactBasic"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rendered response text",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/TextDirectResponse"
                    },
                    {
                      "$ref": "#/components/schemas/ToolWrappedTextResponse"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
