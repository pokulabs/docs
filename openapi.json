  "components": {
    "responses": {
      "BadRequest": {
        "description": "Validation or request error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Authentication required",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "description": "Generic error shape returned by Express error middleware.",
        "additionalProperties": true
      },
      "TextDirectResponse": {
        "type": "string",
        "description": "Rendered text response, timeout message, or image-links summary."
      },
      "NotifyDirectResponse": {
        "type": "object",
        "required": [
          "interaction_id"
        ],
        "properties": {
          "interaction_id": {
            "type": "string",
            "description": "Analytics interaction identifier returned by the executor."
          }
        },
        "additionalProperties": false
      },
      "ContactFormDirectResponse": {
        "oneOf": [
          {
            "type": "string",
            "description": "Timeout or no-response message."
          },
          {
            "type": "object",
            "required": [
              "values",
              "content"
            ],
            "properties": {
              "values": {
                "type": "object",
                "additionalProperties": true,
                "description": "Submitted form values."
              },
              "content": {
                "type": "string",
                "description": "Raw form response body."
              }
            },
            "additionalProperties": false
          }
        ]
      },
      "ToolWrappedTextResponse": {
        "type": "object",
        "required": [
          "results"
        ],
        "properties": {
          "results": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/TextToolResult"
            }
          }
        },
        "additionalProperties": false
      },
      "ToolWrappedNotifyResponse": {
        "type": "object",
        "required": [
          "results"
        ],
        "properties": {
          "results": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/NotifyToolResult"
            }
          }
        },
        "additionalProperties": false
      },
      "ToolWrappedContactFormResponse": {
        "type": "object",
        "required": [
          "results"
        ],
        "properties": {
          "results": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/components/schemas/ContactFormToolResult"
            }
          }
        },
        "additionalProperties": false
      },
      "TextToolResult": {
        "type": "object",
        "required": [
          "toolCallId",
          "result"
        ],
        "properties": {
          "toolCallId": {
            "type": "string"
          },
          "result": {
            "$ref": "#/components/schemas/TextDirectResponse"
          }
        },
        "additionalProperties": false
      },
      "NotifyToolResult": {
        "type": "object",
        "required": [
          "toolCallId",
          "result"
        ],
        "properties": {
          "toolCallId": {
            "type": "string"
          },
          "result": {
            "$ref": "#/components/schemas/NotifyDirectResponse"
          }
        },
        "additionalProperties": false
      },
      "ContactFormToolResult": {
        "type": "object",
        "required": [
          "toolCallId",
          "result"
        ],
        "properties": {
          "toolCallId": {
            "type": "string"
          },
          "result": {
            "$ref": "#/components/schemas/ContactFormDirectResponse"
          }
        },
        "additionalProperties": false
      },
      "Message": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000
      },
      "LongMessage": {
        "type": "string",
        "minLength": 1,
        "maxLength": 10000
      },
      "PhoneOrHandle": {
        "type": "string",
        "minLength": 1,
        "maxLength": 20
      },
      "WaitTime": {
        "type": "number",
        "minimum": 1,
        "maximum": 600,
        "default": 590
      },
      "FollowUpTime": {
        "type": "number",
        "minimum": 1,
        "maximum": 60000,
        "default": 60000
      },
      "Medium": {
        "type": "string",
        "enum": [
          "sms",
          "whatsapp",
          "slack"
        ]
      },
      "CaptureFormFieldOption": {
        "type": "object",
        "required": [
          "label",
          "value"
        ],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "value": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          }
        },
        "additionalProperties": false
      },
      "CaptureFormStringValidationRule": {
        "type": "object",
        "required": [
          "title",
          "pattern"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "pattern": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "description": "Must be a valid regular expression."
          }
        },
        "additionalProperties": false
      },
      "CaptureFormField": {
        "type": "object",
        "required": [
          "id",
          "label",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "pattern": "^[a-zA-Z0-9_-]+$"
          },
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "type": {
            "type": "string",
            "enum": [
