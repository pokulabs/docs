        "operationId": "sendChannelForm",
        "parameters": [
          {
            "name": "channelId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FormBasicInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Form response or timeout message",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/ContactFormDirectResponse"
                    },
                    {
                      "$ref": "#/components/schemas/ToolWrappedContactFormResponse"
                    }
                  ]
                }
              }
            }
          },
          "400": {
