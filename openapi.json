{
  "openapi": "3.1.0",
  "info": {
    "title": "Poku API",
    "version": "1.0.0",
    "description": "OpenAPI document for the authenticated Poku API routes."
  },
  "servers": [
    {
      "url": "https://api.pokulabs.com"
    }
  ],
  "tags": [
    {
      "name": "numbers"
    },
    {
      "name": "calls"
    },
    {
      "name": "messages"
    },
    {
      "name": "forms"
    },
    {
      "name": "webhooks"
    }
  ],
  "paths": {
    "/numbers": {
      "get": {
        "tags": [
          "numbers"
        ],
        "summary": "List reserved numbers",
        "description": "Requires authentication..",
        "operationId": "listReservedNumbersAlias",
        "responses": {
          "200": {
            "description": "Reserved numbers for the authenticated user",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ReservedPhoneNumber"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/numbers/available": {
      "get": {
        "tags": [
          "numbers"
        ],
        "summary": "List available numbers",
        "description": "Requires authentication.",
        "operationId": "listAvailableNumbersAlias",
        "parameters": [
          {
            "name": "country",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "US",
                "GB"
              ],
              "default": "US"
            }
          },
          {
            "name": "areaCode",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 100,
              "maximum": 999
            },
            "description": "Only used for US numbers."
          }
        ],
        "responses": {
          "200": {
            "description": "Available phone numbers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AvailableReservedNumber"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/numbers/reserve": {
      "post": {
        "tags": [
          "numbers"
        ],
        "summary": "Reserve a phone number",
        "description": "Requires authentication.",
        "operationId": "reserveNumberAlias",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReservePhoneNumberRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reserved number record",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReservedPhoneNumber"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/numbers/{reservedNumberId}": {
      "delete": {
        "tags": [
          "numbers"
        ],
        "summary": "Delete a reserved number",
        "description": "Requires authentication.",
        "operationId": "deleteReservedNumberAlias",
        "parameters": [
          {
            "name": "reservedNumberId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "$ref": "#/components/responses/NoContent"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/numbers/{reservedNumberId}/messages": {
      "get": {
        "tags": [
          "numbers"
        ],
        "summary": "List messages for a reserved number",
        "description": "Requires authentication.",
        "operationId": "listReservedNumberMessagesAlias",
        "parameters": [
          {
            "name": "reservedNumberId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent inbound and outbound messages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ReservedNumberMessage"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/calls": {
      "post": {
        "tags": [
          "calls"
        ],
        "summary": "Start a conversation call",
        "description": "Requires authentication.",
        "operationId": "createCall",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
